#
# completion / fzf-tab
#

# Let fzf-tab own the completion UI instead of zsh's built-in menu.
zstyle ':completion:*' menu no
# Show completion groups in the picker.
zstyle ':completion:*:descriptions' format '[%d]'
# Reuse LS_COLORS so file candidates stay colorized inside fzf-tab.
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
# Seed the search box with the current word and allow group switching.
zstyle ':fzf-tab:*' query-string input
zstyle ':fzf-tab:*' switch-group '<' '>'
# Keep the picker compact and anchored near the prompt.
zstyle ':fzf-tab:*' fzf-flags --height=60% --layout=reverse

